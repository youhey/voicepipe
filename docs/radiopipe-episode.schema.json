{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/youhey/voicepipe/docs/radiopipe-episode.schema.json",
  "title": "voicepipe radiopipe episode rendering subset",
  "type": "object",
  "required": ["episode"],
  "additionalProperties": true,
  "properties": {
    "episode": {
      "type": "object",
      "required": ["episode_key", "title", "language", "scenario_json"],
      "additionalProperties": true,
      "properties": {
        "episode_key": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "language": {
          "const": "ja"
        },
        "scenario_json": {
          "type": "object",
          "required": ["sections"],
          "additionalProperties": true,
          "properties": {
            "sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "title", "text"],
                "additionalProperties": true,
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
